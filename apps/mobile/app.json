{
  "expo": {
    "name": "Viaje GPS",
    "slug": "viaje-gps-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.viajegps.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "La app necesita tu ubicacion para compartir tu posicion durante el viaje.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "La app puede usar tu ubicacion para mantener actualizado al coordinador del viaje."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#0b3a47"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.viajegps.mobile"
    },
    "plugins": [
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "c2e4d933-c6d5-44e4-934a-216850b8c59f"
      }
    }
  }
}
